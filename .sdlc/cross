#!/usr/bin/env bash

set -euo pipefail

tool_source="${BASH_SOURCE[0]}"
while [ -h "$tool_source" ]; do tool_source="$(readlink "$tool_source")"; done
sdlc_dir="$( cd -P "$( dirname "$tool_source" )" && pwd )"
prj_home="$( cd -P "$( dirname "$sdlc_dir" )" && pwd )"

cd "${prj_home}"

APP_NAME="paq"
DIST_DIR="dist"
# Le variabili Version/Revision/BuildTime stanno nel package main di cmd/paq.
VERSION_PKG="main"

# Version: use APP_VERSION env var if set, otherwise read VERSION file, otherwise derive from git tags.
if [ -n "${APP_VERSION:-}" ]; then
    app_version="${APP_VERSION}"
elif [ -f "${prj_home}/VERSION" ]; then
    app_version="$(cat "${prj_home}/VERSION" | tr -d '[:space:]')"
else
    app_version="$(git describe --tags --always --dirty 2>/dev/null || echo "dev")"
fi

buildtime="$(TZ=UTC date -u '+%Y-%m-%dT%H:%M:%SZ')"
git_hash="$(git rev-parse HEAD 2>/dev/null || echo "unknown")"
git_dirty="$(test -n "$(git status --porcelain 2>/dev/null)" && echo "+CHANGES" || true)"
git_commit="${git_hash}${git_dirty}"

ldflags="-s \
    -X ${VERSION_PKG}.Version=${app_version} \
    -X ${VERSION_PKG}.BuildTime=${buildtime} \
    -X ${VERSION_PKG}.Revision=${git_commit}"

# Target di cross-compilazione: "os/arch".
targets=(
    "linux/amd64"
    "linux/arm64"
    "darwin/amd64"
    "darwin/arm64"
    "windows/amd64"
    "windows/arm64"
)

echo "==> cross-build ${APP_NAME}"
echo "    version : ${app_version}"
echo "    git     : ${git_commit}"

mkdir -p "${DIST_DIR}"

for target in "${targets[@]}"; do
    goos="${target%/*}"
    goarch="${target#*/}"
    ext=""
    if [ "${goos}" = "windows" ]; then
        ext=".exe"
    fi
    out="${DIST_DIR}/${APP_NAME}-${goos}-${goarch}${ext}"
    echo "    -> ${out}"
    GOOS="${goos}" GOARCH="${goarch}" go build \
        -ldflags "${ldflags}" \
        -o "${out}" \
        "./cmd/${APP_NAME}"
done

echo "==> ok  ${DIST_DIR}/"
