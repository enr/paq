#!/usr/bin/env bash

set -e

tool_source="${BASH_SOURCE[0]}"
while [ -h "$tool_source" ] ; do tool_source="$(readlink "$tool_source")"; done
sdlc_dir="$( cd -P "$( dirname "$tool_source" )" && pwd )"
prj_home="$( cd -P "$( dirname "$sdlc_dir" )" && pwd )"

echo "Project home ${prj_home}"
cd "${prj_home}"

hash grep 2>/dev/null || {
  echo 'No Grep executable: aborting release'
  exit 1
}

hash git 2>/dev/null || {
  echo 'No Git executable: aborting release'
  exit 1
}

git rev-parse --abbrev-ref --symbolic-full-name '@{u}' || {
  echo 'No upstream set for current branch: aborting release'
  exit 1
}

upstream='@{u}'
local_branch=$(git rev-parse @)
remote_branch=$(git rev-parse "$upstream")

[[ "$local_branch" = "$remote_branch" ]] || {
  echo "Local branch ${local_branch} and remote ${remote_branch} are not aligned: aborting release"
  exit 1
}

[[ -n "$1" ]] || {
  echo 'Missing release version: aborting release'
  echo 'Usage: release <release_version> <next_snapshot_version>'
  echo 'Example: release 1.2.3 1.2.4'
  exit 1
}
release_version="${1}"
echo "Release version: ${release_version}"

[[ -n "$2" ]] || {
  echo 'Missing next snapshot version: aborting release'
  echo 'Usage: release <release_version> <next_snapshot_version>'
  echo 'Example: release 1.2.3 1.2.4'
  exit 1
}
snapshot_version="${2}-SNAPSHOT"
echo "Snapshot version: ${snapshot_version}"

tag_name="v${release_version}"
tag_exists=$(git tag -l "${tag_name}")
[[ -n "$tag_exists" ]] && {
  echo "Tag ${tag_name} exists: aborting release"
  exit 1
}

git_dirty=$(git status --porcelain)
[[ -n "$git_dirty" ]] && {
  echo 'Uncommitted changes detected: aborting release'
  exit 1
}

echo "Release ${release_version} (tag ${tag_name}), then snapshot ${snapshot_version}"

function cleanup() {
    echo "Cleanup..."
}
trap cleanup EXIT
trap cleanup SIGINT

# --- release commit ---
echo "${release_version}" > VERSION
sed -i "s/^  currentAppVersion = .*/  currentAppVersion = \"${release_version}\"/" docs/hugo.toml
git add VERSION docs/hugo.toml
git commit -m "release ${release_version}"
git tag -a "${tag_name}" -m "Release ${release_version}"

# --- back to snapshot ---
echo "${snapshot_version}" > VERSION
sed -i "s/^  currentAppVersion = .*/  currentAppVersion = \"${snapshot_version}\"/" docs/hugo.toml
git add VERSION docs/hugo.toml
git commit -m "[skip ci] prepare snapshot ${snapshot_version}"

git push
git push --tags
