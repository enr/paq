#!/usr/bin/env bash

set -e

tool_source="${BASH_SOURCE[0]}"
while [ -h "$tool_source" ] ; do tool_source="$(readlink "$tool_source")"; done
sdlc_dir="$( cd -P "$( dirname "$tool_source" )" && pwd )"
prj_home="$( cd -P "$( dirname "$sdlc_dir" )" && pwd )"

cd "${prj_home}"

echo "==> build"
go build ./...

echo "==> test"
set +e
test_output=$(go test -count=1 -v ./... 2>&1)
test_exit=$?
set -e
echo "$test_output" | grep -E "^(ok|FAIL|---)"
total=$(echo "$test_output" | grep -c "^--- " || true)
if [ $test_exit -ne 0 ]; then
  echo "==> FAILED — full output:"
  echo "$test_output"
  exit $test_exit
fi
echo "==> ok (${total} tests)"
